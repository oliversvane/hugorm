# hugorm frontend config. Copy to .env.local and fill in.
#
# supabase-js needs the base URL + anon key. We route Supabase traffic
# through the FastAPI host (/auth/v1/* is proxied to GoTrue), so both
# point to the same origin.

NEXT_PUBLIC_SUPABASE_URL=http://localhost:8002
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY_FROM_deploy/.env
NEXT_PUBLIC_API_URL=http://localhost:8002
