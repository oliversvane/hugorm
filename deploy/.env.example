# Supabase self-hosted secrets for hugorm.
# Fill these in by running: uv run python deploy/gen_secrets.py > deploy/.env

POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

JWT_EXPIRY=3600
SITE_URL=http://localhost:8002
API_EXTERNAL_URL=http://localhost:9999
ADDITIONAL_REDIRECT_URLS=http://localhost:8002/**
DISABLE_SIGNUP=false
